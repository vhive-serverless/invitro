{
  "Seed": 42,

  "Platform": "nexus",
  "InvokeProtocol" : "grpc",
  "YAMLSelector": "nexus",
  "EndpointPort": 80,

  "BusyLoopOnSandboxStartup": false,

  "TracePath": "data/traces/nexus",
  "Granularity": "minute",
  "OutputPathPrefix": "data/out/baseline_d-100_s-1_e-14_t-1_p-true/experiment",
  "IATDistribution": "equidistant",
  "CPULimit": "1vCPU",
  "ExperimentDuration": 14,
  "WarmupDuration": 5,

  "IsPartiallyPanic": false,
  "EnableZipkinTracing": false,
  "EnableMetricsScrapping": true,
  "MetricScrapingPeriodSeconds": 1,
  "AutoscalingMetric": "concurrency",

  "GRPCConnectionTimeoutSeconds": 20,
  "GRPCFunctionTimeoutSeconds": 900,
  "DAGMode": false,
  "EnableDAGDataset": true,
  "Width": 2,
  "Depth": 2,
  
  "EnablePrefetch": true
}
